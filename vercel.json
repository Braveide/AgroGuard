{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://<TU_BACKEND>.vercel.app/api/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "max-age=0, s-maxage=86400, stale-while-revalidate=86400"
        }
      ]
    }
  ]
}
