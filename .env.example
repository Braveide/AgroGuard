# Puerto y host donde correrá FastAPI (usado por Docker)
PORT=8000
HOST=0.0.0.0

# Supabase (PostgreSQL) – usa la clave anónima para acceso público
# En producción, crea una variable SUPABASE_KEY con el mismo valor que SUPABASE_ANON_KEY
# (Supabase necesita la clave para autenticación, incluso en modo anónimo).
SUPABASE_URL=https://<your-project>.supabase.co

SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRwc3J4bndnZHd2cm9zb2x3anBkIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkxMjgyMDEsImV4cCI6MjA5NDcwNDIwMX0.SVptLxfrKO1Nr5oQMT4LjdelF77QDmPP3oIzmwv6jzM
# Opcional: si prefieres usar SUPABASE_KEY explícitamente, añade también:
# SUPABASE_KEY=${SUPABASE_ANON_KEY}

# Gemini (u otro modelo de IA) – solo si lo usas
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Claves que usa la UI (pueden ser cualquier cadena)
API_PUBLIC_KEY=my-public-key
API_SECRET_KEY=my-secret-key
